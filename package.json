{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "db:codegen": "npx kysely-codegen --out-file src/db/types.ts",
    "db:make-migration": "npx kysely migrate:make",
    "db:migrate": "npx kysely migrate:latest",
    "db:make-seed": "npx kysely seed:make",
    "db:seed": "npx kysely seed:run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "pnpm run test:unit && pnpm run test:i",
    "test:unit": "vitest run ./src/**",
    "test:i": "dotenv -e .env.test vitest run --setup-files tests/integration/setup.ts ./tests/integration/** ",
    "pretest:i": "docker compose -f docker-compose-test.yml --env-file .env.test up -d --wait && dotenv -e .env.test -- pnpm run db:migrate && dotenv -e .env.test -- pnpm run db:seed",
    "posttest:i": "docker compose -f docker-compose-test.yml down"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@hono/node-server": "^1.19.6",
    "@hono/zod-validator": "^0.7.6",
    "dotenv": "^17.2.3",
    "geo-tz": "^8.1.5",
    "hono": "^4.11.1",
    "kysely": "^0.28.9",
    "kysely-ctl": "^0.19.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stoker": "^2.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "dotenv-cli": "^11.0.0",
    "kysely-codegen": "^0.19.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
