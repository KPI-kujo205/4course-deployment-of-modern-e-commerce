{
	"name": "api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"start": "npx tsx src/index.ts",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"db:codegen": "npx kysely-codegen --out-file src/db/types.ts",
		"db:make-migration": "npx kysely migrate:make",
		"db:migrate": "npx kysely migrate:latest",
		"db:make-seed": "npx kysely seed:make",
		"db:seed": "npx kysely seed:run",
		"db:up": "docker compose up -d",
		"db:down": "docker compose down",
		"test": "pnpm run test:unit && pnpm run test:i",
		"test:unit": "dotenv -e .env.test vitest run ./src/**",
		"test:i": "dotenv -e .env.test -- pnpm exec vitest run --config vitest.integration.config.ts",
		"pretest:i": "docker compose -f docker-compose-test.yml --env-file .env.test up -d --wait && dotenv -e .env.test -- pnpm run db:migrate && dotenv -e .env.test -- pnpm run db:seed",
		"posttest:i": "docker compose -f docker-compose-test.yml down"
	},
	"dependencies": {
		"@grammyjs/conversations": "^2.1.1",
		"@hono/node-server": "^1.19.10",
		"@hono/zod-validator": "^0.7.6",
		"api": "link:",
		"dotenv": "^17.3.1",
		"geo-tz": "^8.1.5",
		"grammy": "^1.41.1",
		"hono": "^4.12.4",
		"kysely": "^0.28.11",
		"kysely-ctl": "^0.20.0",
		"node-cron": "^4.2.1",
		"pg": "^8.19.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"stoker": "^2.0.1",
		"tsx": "^4.21.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^25.3.3",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.18.0",
		"dotenv-cli": "^11.0.0",
		"kysely-codegen": "^0.20.0",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
