{
	"compilerOptions": {
		"target": "ES2022",
		"declaration": true,
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"types": ["node", "vitest/globals"],
		"jsx": "react",
		"jsxFactory": "jsx",
		"jsxFragmentFactory": "Fragment",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@core/*": ["./src/core/*"],
			"@infra/*": ["./src/infra/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.mts",
		"src/**/*.test.ts",
		"src/**/*.test.tsx"
	],
	"exclude": ["node_modules/*"]
}
